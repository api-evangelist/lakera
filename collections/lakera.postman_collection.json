  "info": {
    "_postman_id": "00a79f5e-6f8a-4366-a3c8-37717a62e80f",
    "name": "Lakera Guard API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Lakera Guard is an AI security API that screens text content sent to and received from large language models. It detects prompt injection, jailbreaks, PII, unsafe content, and policy violations, returning flagged decisions and detailed detector results. Authentication uses a bearer token issued in the Lakera dashboard. Self-hosted deployments expose additional policy management and Kubernetes probe endpoints.\n\nContact Support:\n Name: Lakera",
      "type": "text/plain"
    }
  }
